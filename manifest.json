{
  "manifest_version": 3,
  "name": "Toledo Lecture Downloader",
  "version": "1.0.0",
  "description": "Download KU Leuven Toledo college video lectures in high quality with a single click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "toledodownloader@albin.curiel",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "downloads",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.kuleuven.cloud/*",
    "https://*.kuleuven.be/*",
    "https://*.kaltura.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.kuleuven.cloud/*",
        "https://*.kuleuven.be/*",
        "https://*.kaltura.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/popup.html", "icons/icon128.png"],
      "matches": ["https://*.kuleuven.cloud/*", "https://*.kuleuven.be/*"]
    }
  ]
}
